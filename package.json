{
  "name": "openclaw",
  "version": "2026.3.15",
  "description": "Minimal cellular agent engine for spreadsheet deployment",
  "keywords": ["ai", "agents", "cells", "spreadsheet", "automation"],
  "homepage": "https://github.com/SuperInstance/claw#readme",
  "bugs": {
    "url": "https://github.com/SuperInstance/claw/issues"
  },
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SuperInstance/claw.git"
  },
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "docs/",
    "extensions/",
    "dist/"
  ],
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "node scripts/tsdown-build.mjs && node scripts/runtime-postbuild.mjs",
    "check": "pnpm format:check && pnpm tsgo && pnpm lint",
    "dev": "node scripts/run-node.mjs",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix && pnpm format",
    "start": "node scripts/run-node.mjs",
    "test": "node scripts/test-parallel.mjs",
    "test:coverage": "vitest run --config vitest.unit.config.ts --coverage",
    "test:fast": "vitest run --config vitest.unit.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "ajv": "^8.18.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "hono": "4.12.7",
    "tslog": "^4.10.2",
    "undici": "^7.24.1",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^28.1.0",
    "oxfmt": "0.40.0",
    "oxlint": "^1.55.0",
    "tsdown": "0.21.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "packageManager": "pnpm@10.23.0",
  "pnpm": {
    "minimumReleaseAge": 2880,
    "overrides": {
      "hono": "4.12.7",
      "@hono/node-server": "1.19.10"
    }
  }
}
